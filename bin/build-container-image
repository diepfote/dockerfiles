#!/usr/bin/env bash

set -o pipefail  # propagate errors
set -u  # exit on undefined
set -e  # exit on non-zero return value
#set -f  # disable globbing/filename expansion
shopt -s failglob  # error on unexpaned globs

cleanup () { set +x; }
trap cleanup EXIT

(
  cd ~/Repos/dockerfiles/"$1"


  # @TODO `-v`/`--mount` no longer works in builds
  # you need to use: --mount=type=cache
  # It cannot be used (as a flag or option) with the docker build command directly.
  # Instead, cache mounts are specified inside your Dockerfile as part of a RUN instruction,
  # and only work when Docker BuildKit is enabled.
  #
  # Dockerfile:
  # RUN --mount=type=cache,target=/path/to/cache-dir your-command
  #
  # build_opts+=('-v' '/var/cache/pkgfile:/var/cache/host-pkgfile:ro' '-v' '/var/cache/pacman:/var/cache/host-pacman:ro' '--no-cache')
  # build_opts+=('-v' '/var/cache/pkgfile:/var/cache/pkgfile' \
  #   '-v' '/var/cache/pacman:/var/cache/pacman' \
  #   '--no-cache')

  set -x
  docker build "${build_opts[@]}" -t "$1" .
  set +x

  if [ "$(uname)" != Linux ]; then
    docker tag "$1":latest localhost/"$1":latest
  fi
)
